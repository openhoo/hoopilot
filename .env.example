# Client API key. Leave empty for the keyless local flow (loopback only). Set a
# strong, unique value (e.g. `openssl rand -hex 24`) only when exposing the proxy
# beyond loopback; clients must then send it as `Authorization: Bearer <key>` or
# `x-api-key: <key>`. NOTE: docker compose reads this file, so a value here is
# enforced and would reject codexx's keyless throwaway key.
HOOPILOT_API_KEY=
# Run without a client key. Safe when the proxy is published on loopback only,
# as docker-compose.yml is. Clear it to fail closed on a non-loopback bind.
HOOPILOT_ALLOW_UNAUTHENTICATED=1
HOOPILOT_AUTH_FILE=
HOOPILOT_GITHUB_CLIENT_ID=
HOOPILOT_GITHUB_DOMAIN=github.com
HOOPILOT_GITHUB_API_BASE_URL=https://api.github.com
HOOPILOT_ALLOW_UNSAFE_UPSTREAM=
HOOPILOT_LOG_FORMAT=pretty
HOOPILOT_LOG_LEVEL=info
HOOPILOT_NO_UPDATE_CHECK=
NO_UPDATE_NOTIFIER=
HOST=127.0.0.1
PORT=4141
COPILOT_API_BASE_URL=https://api.githubcopilot.com
