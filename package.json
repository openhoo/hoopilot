{
  "name": "@openhoo/hoopilot",
  "version": "0.6.1",
  "packageManager": "bun@1.3.14",
  "description": "OpenAI-compatible local proxy for GitHub Copilot accounts.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/openhoo/hoopilot.git"
  },
  "bugs": {
    "url": "https://github.com/openhoo/hoopilot/issues"
  },
  "homepage": "https://github.com/openhoo/hoopilot#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "bin": {
    "codexx": "dist/codexx.js",
    "hoopilot": "dist/cli.js"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --sourcemap --clean && tsup src/cli.ts src/codexx.ts --format esm --sourcemap",
    "build:binaries": "bash scripts/build-binaries.sh",
    "biome:check": "biome ci --error-on-warnings .",
    "biome:fix": "biome check --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "typecheck": "tsc --noEmit",
    "check": "bun run biome:check && bun run typecheck && bun run test:coverage && bun run build",
    "hooks:install": "if git rev-parse --git-dir >/dev/null 2>&1; then git config core.hooksPath .githooks; fi",
    "prepare": "bun run hooks:install",
    "prepack": "bun run build",
    "verify": "bun run typecheck && bun run test:coverage && bun run build"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@openhoo/hooversion": "0.1.1",
    "@types/bun": "^1.3.14",
    "@types/node": "^25.9.1",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3"
  }
}
